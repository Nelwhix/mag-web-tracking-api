generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String   @id @default(ulid())
  name         String
  database_url String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("tenants")
}
